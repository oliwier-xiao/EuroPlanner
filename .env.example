# ============================================================
# Supabase
# ============================================================
# Pobierz z: https://supabase.com/dashboard/project/_/settings/api

# URL projektu (publiczny, używany też po stronie klienta)
NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co

# Anon key (publiczny, używany w przeglądarce, respektuje RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SEKRETNY, omija RLS, TYLKO server-side)
# UWAGA: nigdy nie commituj tego klucza i nie dawaj mu prefiksu NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# Google Cloud Vision (OCR paragonów) - opcjonalne dla MVP
# ============================================================
# GOOGLE_VISION_API_KEY=

# ============================================================
# OpenStreetMap / Nominatim
# ============================================================
# Wymagany kontaktowy email w User-Agent zgodnie z polityka Nominatim.
NOMINATIM_CONTACT_EMAIL=twoj-prawdziwy-email@example.com
