// Europlanner - Schemat bazy danych
// Docs: https://dbml.dbdiagram.io/docs
// Podgląd/edycja: https://dbdiagram.io/d
//
// Konwencja: nazwy tabel w PascalCase (Users, Trips, Trip_participants, ...).
// Cały kod aplikacji używa tej formy (np. supabase.from("Users")).

Project europlanner {
  database_type: 'PostgreSQL'
  Note: '''
    # Europlanner Database
    Schemat bazy danych aplikacji Europlanner (Supabase / PostgreSQL).
    Obsługuje planowanie podróży grupowych, listę aktywności oraz wspólne rozliczenia.
  '''
}

Table Users {
  user_id uuid [pk]
  name text
  surname text
  password text [not null]
  Admin_access boolean [default: false, note: 'Uwaga: pisownia z dużej A']
  avatar_id text [default: 'yellow-smile', note: 'FK logiczny → lib/avatars.ts']
  email text [unique, note: 'Opcjonalne przy rejestracji']
}

Table Trips {
  trip_id uuid [pk]
  title varchar [not null]
  description varchar
  start_date date
  end_date date
  budget_limit numeric
  created_at timestamp [default: `now()`]
  slug text [unique, not null, note: 'Unikalny, NOT NULL. Przyjazny identyfikator używany w URL-ach (np. /trips/wakacje-w-pradze-a3f9). Generowany automatycznie z tytułu przez lib/slug.ts (ASCII-only + losowy suffix). Indeks UNIQUE: trips_slug_unique.']
}

Table Trip_participants {
  trip_id uuid [not null]
  user_id uuid [not null]
  role varchar [not null, note: "'owner' | 'member'"]
  joined_at timestamp [default: `now()`]

  indexes {
    (trip_id, user_id) [pk]
  }
}

Table Destinations {
  destination_id bigint [pk, increment]
  trip_id uuid [not null]
  name text [not null]
  lat real
  lng real
  arrival_date date
  departure_date date
  visit_order smallint
}

Table Activities {
  activity_id bigint [pk, increment]
  destination_id bigint [not null]
  title varchar
  start_time timestamp
  cost real
  is_completed boolean [default: false]
}

Table Expense_categories {
  category_id uuid [pk]
  name varchar
}

Table Expenses {
  expense_id uuid [pk]
  trip_id uuid [not null]
  category_id uuid [not null]
  amount real [not null]
  date date [not null]
  note text
}

// Relacje
Ref: Trip_participants.trip_id > Trips.trip_id
Ref: Trip_participants.user_id > Users.user_id

Ref: Destinations.trip_id > Trips.trip_id

Ref: Activities.destination_id > Destinations.destination_id

Ref: Expenses.trip_id > Trips.trip_id
Ref: Expenses.category_id > Expense_categories.category_id
