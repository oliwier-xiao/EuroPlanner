// Europlanner - Schemat bazy danych
// Docs: https://dbml.dbdiagram.io/docs
// Podgląd/edycja: https://dbdiagram.io/d

Project europlanner {
  database_type: 'PostgreSQL'
  Note: '''
    # Europlanner Database
    Schemat bazy danych aplikacji Europlanner (Supabase / PostgreSQL).
    Obsługuje planowanie podróży grupowych oraz wspólne rozliczenia.
  '''
}

Table users {
  user_id uuid [pk]
  name text [not null]
  surname text
  email text
  password text [not null, note: 'Obsługiwane przez Supabase Auth — kolumna poglądowa']
  admin_access boolean [not null, default: false]
  avatar_id text
}

Table trips {
  trip_id uuid [pk]
  slug text [not null]
  title varchar [not null]
  description varchar
  start_date date
  end_date date
  budget_limit numeric
  created_at timestamp [not null]
}

Table trip_participants {
  trip_id uuid [not null]
  user_id uuid
  role varchar [not null, note: "'owner' | 'member'"]
  joined_at timestamp [not null]

  indexes {
    (trip_id, user_id) [unique]
  }
}

Table destinations {
  destination_id bigint [pk]
  trip_id uuid [not null]
  name text [not null]
  lat real
  lng real
  arrival_date date
  departure_date date
  visit_order smallint
}

Table expense_categories {
  category_id uuid [pk]
  name varchar [not null]
}

Table expenses {
  expense_id uuid [pk]
  trip_id uuid [not null]
  category_id uuid
  amount real [not null]
  date date [not null]
  note text
}

// Relacje
Ref: trip_participants.trip_id > trips.trip_id
Ref: trip_participants.user_id > users.user_id

Ref: destinations.trip_id > trips.trip_id

Ref: expenses.trip_id > trips.trip_id
Ref: expenses.category_id > expense_categories.category_id
